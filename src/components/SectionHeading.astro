---
const { num, title } = Astro.props;
---
<div class="flex items-center gap-4 mb-12" data-reveal>
  <h2 class="text-2xl sm:text-4xl font-extrabold tracking-tight whitespace-nowrap">
    {num && <span class="font-mono text-accent text-2xl mr-2">{num}.</span>}{title}
  </h2>
  <span class="h-px bg-border-subtle flex-1"></span>
</div>
