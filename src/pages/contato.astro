---
import Base from "../layouts/Base.astro";
const WHATSAPP = "5579981393307";
const EMAIL = "contato@dynasolutions.com.br";
---
<Base title="Contato · Dyna Solutions">
  <section class="mx-auto max-w-2xl px-6 py-16 sm:py-20">
    <h1 class="text-4xl font-extrabold tracking-tight" data-reveal>Vamos conversar</h1>
    <p class="mt-4 text-text-secondary" data-reveal>Conte seu desafio. Respondo pessoalmente.</p>

    <div id="form-feedback" class="hidden mt-6 rounded-xl border p-4 text-sm font-medium"></div>

    <form action="/contact.php" method="POST" class="mt-10 space-y-4" data-reveal id="form">
      <input type="text" name="_website" class="hidden" tabindex="-1" autocomplete="off" />
      <input required name="name" placeholder="Seu nome" class="w-full rounded-xl bg-bg-raised border border-border-subtle px-4 py-3 outline-none focus:border-accent" />
      <input required type="email" name="email" placeholder="Seu e-mail" class="w-full rounded-xl bg-bg-raised border border-border-subtle px-4 py-3 outline-none focus:border-accent" />
      <textarea required name="message" rows="5" placeholder="Seu desafio / projeto" class="w-full rounded-xl bg-bg-raised border border-border-subtle px-4 py-3 outline-none focus:border-accent"></textarea>
      <button type="submit" id="submit-btn" class="rounded-xl bg-accent text-accent-ink font-bold px-6 py-3 hover:brightness-110 transition disabled:opacity-60 disabled:cursor-not-allowed">Enviar →</button>
    </form>
    <div class="mt-8 flex flex-wrap gap-4 text-sm" data-reveal>
      <a href={`https://wa.me/${WHATSAPP}`} class="text-accent hover:underline">WhatsApp</a>
      <a href={`mailto:${EMAIL}`} class="text-accent hover:underline">{EMAIL}</a>
    </div>
  </section>
</Base>

<script>
  const params = new URLSearchParams(window.location.search);
  const fb = document.getElementById("form-feedback");
  if (params.get("status") === "success") {
    fb.className = "mt-6 rounded-xl border p-4 text-sm font-medium text-accent border-accent/40 bg-accent/10";
    fb.textContent = "Mensagem enviada com sucesso! Responderei em até 24h.";
    fb.classList.remove("hidden");
    history.replaceState(null, "", "/contato");
  } else if (params.get("status") === "error") {
    const msg = params.get("msg") || "Erro ao enviar. Tente novamente.";
    fb.className = "mt-6 rounded-xl border p-4 text-sm font-medium text-red-400 border-red-400/40 bg-red-400/10";
    fb.textContent = msg;
    fb.classList.remove("hidden");
    history.replaceState(null, "", "/contato");
  }

  // Trava o botão ao enviar (evita duplo envio e dá feedback)
  const form = document.getElementById("form") as HTMLFormElement | null;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  form?.addEventListener("submit", () => {
    if (!btn) return;
    btn.disabled = true;
    btn.textContent = "Enviando…";
  });
</script>
